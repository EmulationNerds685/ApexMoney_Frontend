# ============================================
# REQUIRED - MUST SET BEFORE DEPLOYING
# ============================================

# Backend API URL
# Set to your Render backend URL in production
VITE_BACKENDURL=http://localhost:8000

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com/
# Example: G-XXXXXXXXXX
VITE_GA_ID=G-YOUR_MEASUREMENT_ID_HERE

# ============================================
# ENVIRONMENT
# ============================================

# Build environment (development, production, etc)
VITE_ENV=production
